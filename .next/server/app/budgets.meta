    "x-next-cache-tags": "_N_T_/layout,_N_T_/(app)/layout,_N_T_/(app)/budgets/layout,_N_T_/(app)/budgets/page,_N_T_/budgets"
  },
  "segmentPaths": [
    "/_tree",
